# ── Feature Flags ─────────────────────────────────────────────────────────────
# Comma-separated list of feature flag names to enable at build time.
# Flags present in this list are enabled; absent flags default to false.
# Example: VITE_FLAGS=new_dashboard,experimental_sync
# Flag names are case-insensitive. The value is baked into the JS bundle by
# Vite at compile time and read by src/flags.ts on startup.
# For a future remote override, use loadRemoteFlags() in flags.ts.
VITE_FLAGS=

# Brandfetch API (https://www.brandfetch.com/developers)
VITE_BRANDFETCH_CLIENT_ID=

# Amplitude Analytics (https://amplitude.com)
# Read at Rust compile time via option_env!(); never exposed in the JS bundle.
# Leave blank in dev; set in CI/CD for production builds.
AMPLITUDE_API_KEY=

# Attio CRM — newsletter subscription (https://attio.com)
# Read at Rust compile time via option_env!(); never exposed in the JS bundle.
# Leave blank in dev; set in CI/CD for production builds.
ATTIO_API_KEY=

# Apple code signing + notarization
# Required for macOS builds to pass Gatekeeper.
# APPLE_ID: your Apple ID email (Apple Developer account)
# APPLE_PASSWORD: app-specific password from appleid.apple.com
# APPLE_TEAM_ID: your 10-char team ID from developer.apple.com/account
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
